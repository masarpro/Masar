{
	"name": "supastarter-nextjs",
	"private": true,
	"scripts": {
		"build": "dotenv -c -- turbo build",
		"dev": "dotenv -c -- turbo dev --concurrency 15",
		"type-check": "dotenv -c -- turbo type-check",
		"start": "dotenv -c -- turbo start",
		"lint": "biome lint . ",
		"check": "biome check",
		"test": "dotenv -c -- turbo test",
		"test:api": "pnpm --filter @repo/api test",
		"test:db": "pnpm --filter @repo/database test",
		"test:coverage": "dotenv -c -- turbo test -- --coverage",
		"clean": "turbo clean",
		"format": "biome format . --write",
		"prepare": "husky"
	},
	"engines": {
		"node": ">=20"
	},
	"packageManager": "pnpm@10.14.0",
	"devDependencies": {
		"@biomejs/biome": "2.3.5",
		"@repo/tsconfig": "workspace:*",
		"@types/node": "^24.10.1",
		"asn1.js": "^5.4.1",
		"dotenv-cli": "^11.0.0",
		"husky": "^9.1.7",
		"tsx": "^4.21.0",
		"turbo": "^2.7.2",
		"typescript": "5.9.3",
		"vitest": "^4.0.18"
	},
	"pnpm": {
		"overrides": {
			"@types/pg": "8.15.6"
		},
		"onlyBuiltDependencies": [
			"@prisma/client",
			"@prisma/engines",
			"@swc/core",
			"esbuild",
			"prisma",
			"prisma-zod-generator",
			"sharp"
		]
	},
	"dependencies": {
		"@sindresorhus/slugify": "^3.0.0"
	}
}
