{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"framework": "nextjs",
	"installCommand": "pnpm install",
	
	"functions": {
		"apps/web/app/api/**/*.ts": {
			"maxDuration": 60
		}
	},
	"crons": [
		{
			"path": "/api/health",
			"schedule": "*/5 * * * *"
		},
		{
			"path": "/api/cron/update-overdue-invoices",
			"schedule": "0 0 * * *"
		},
		{
			"path": "/api/cron/cleanup-expired-tokens",
			"schedule": "0 2 * * *"
		},
		{
			"path": "/api/cron/daily",
			"schedule": "0 3 * * *"
		}
	]
}
