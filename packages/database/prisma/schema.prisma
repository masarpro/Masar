  receiptVouchers         ReceiptVoucher[]
  paymentVouchers         PaymentVoucher[]
  handoverProtocols       HandoverProtocol[]

  // ═══ نهاية حقول مسار ═══

  @@unique([slug])
  @@index([status])
  @@index([plan])
  @@index([subscriptionStatus])
  @@map("organization")
