  companyExpenseRuns   CompanyExpenseRun[]

  // Audit Trail - سجل التدقيق
  orgAuditLogs         OrganizationAuditLog[]

  // Employee Change Logs - سجل تغييرات الموظفين
  employeeChangeLogs   EmployeeChangeLog[]

  // Notification Preferences - تفضيلات الإشعارات
  notificationPreferences NotificationPreference[]

  // Leave Management - إدارة الإجازات
  leaveTypes           LeaveType[]
  leaveRequests        LeaveRequest[]

  // Atomic Sequences - التسلسلات الذرية
  sequences            OrganizationSequence[]

  // Accounting - المحاسبة
  chartAccounts        ChartAccount[]
  journalEntries       JournalEntry[]
  accountingPeriods    AccountingPeriod[]
  recurringJournalTemplates RecurringJournalTemplate[]
  bankReconciliations  BankReconciliation[]

  // ═══ Subscription & Billing - الاشتراكات والفوترة ═══
