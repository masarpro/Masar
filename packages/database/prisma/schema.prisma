  // Finance Module - المالية
  clients              Client[]
  quotations           Quotation[]
  financeInvoices      FinanceInvoice[]
  openDocuments        OpenDocument[]
  financeTemplates     FinanceTemplate[]

  // Organization Finance - المالية المؤسسية
